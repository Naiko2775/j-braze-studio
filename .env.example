# ===========================================
# J-Braze Studio - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# On Vercel, set these in Project Settings > Environment Variables.

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/jbraze?sslmode=require

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Braze ---
BRAZE_API_KEY=your-braze-api-key
BRAZE_API_URL=https://rest.iad-01.braze.com

# --- Brevo (optional - for migration module) ---
BREVO_API_KEY=

# --- Salesforce Marketing Cloud (optional - for migration module) ---
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_SUBDOMAIN=

# --- Vercel-specific (auto-set by Vercel, no need to configure manually) ---
# VERCEL=1
# VERCEL_ENV=production
