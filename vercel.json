{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "apps/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/apps/api/index.py" },
    { "src": "/assets/(.*)", "dest": "/apps/web/assets/$1" },
    { "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|eot|map))", "dest": "/apps/web/$1" },
    { "src": "/(.*)", "dest": "/apps/web/index.html" }
  ]
}
